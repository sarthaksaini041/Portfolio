<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sarthak Saini | CSE Student</title>
    <meta name="description" content="Portfolio of Sarthak Saini, a CSE student at GLA University, building ML pipelines and student communities.">
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=Space+Grotesk:wght@300..700&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --bg: #0d0d0d;
            --accent: #ff0000;
            --accent-glow: rgba(255, 0, 0, 0.2);
            --text-main: #e0e0e0;
            --text-dim: #a0a0a0;
            --grid-line: rgba(255, 255, 255, 0.04);
            --grid-dot: rgba(255, 0, 0, 0.15);
            --sans: 'Space Grotesk', sans-serif;
            --body: 'DM Sans', sans-serif;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            cursor: none;
        }

        body {
            background-color: #ffffff; /* White layer underneath */
            color: var(--text-main);
            font-family: var(--body);
            overflow-x: hidden;
            line-height: 1.6;
            opacity: 0;
        }

        h1, h2, h3 {
            font-family: var(--sans);
            font-weight: 700;
            text-transform: lowercase;
        }

        a {
            color: inherit;
            text-decoration: none;
        }

        /* Custom Cursor */
        #cursor-dot {
            position: fixed;
            width: 6px;
            height: 6px;
            background: var(--accent);
            border-radius: 50%;
            pointer-events: none;
            z-index: 9999;
            transform: translate(-50%, -50%);
        }

        #cursor-ring {
            position: fixed;
            width: 40px;
            height: 40px;
            border: 1px solid var(--accent);
            border-radius: 50%;
            pointer-events: none;
            z-index: 9998;
            transform: translate(-50%, -50%);
            transition: width 0.3s, height 0.3s;
        }

        /* Scroll Progress */
        #scroll-progress {
            position: fixed;
            right: 20px;
            top: 50%;
            transform: translateY(-50%);
            width: 2px;
            height: 150px;
            background: rgba(255, 255, 255, 0.1);
            z-index: 100;
        }

        #scroll-bar {
            width: 100%;
            height: 0%;
            background: var(--accent);
            position: absolute;
            top: 0;
        }

        /* Hero Section */
        section {
            min-height: 100vh;
            padding: 100px 10%;
            display: flex;
            flex-direction: column;
            justify-content: center;
            position: relative;
        }

        #hero {
            background-color: var(--bg); /* Dark Hero */
            padding-bottom: 260px; /* Reduced to end just after strips */
            z-index: 10;
            border-radius: 0; 
            margin-bottom: -80px; 
            overflow: visible;
        }

        #hero h1 {
            font-size: clamp(3rem, 10vw, 8rem);
            line-height: 0.9;
            margin-bottom: 20px;
            display: flex;
            overflow: hidden;
        }

        .char {
            display: inline-block;
            transform: translateY(100%);
        }

        .hero-sub {
            font-size: 1.2rem;
            color: var(--text-dim);
            margin-bottom: 30px;
            opacity: 0;
            transform: translateY(20px);
        }

        .hero-bio {
            max-width: 600px;
            font-size: 1.5rem;
            font-weight: 400;
            opacity: 0;
            transform: translateY(20px);
        }

        /* Transition Strips - Red & White Criss Cross */
        .transition-strip {
            position: absolute;
            bottom: 220px; /* Elevated for visibility within Hero */
            left: -10%;
            width: 120%;
            background: #ff0000; /* Deadpool Red */
            padding: 15px 0;
            overflow: hidden;
            z-index: 20;
            transform: rotate(-2deg);
            transform-origin: center;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        }
        
        .transition-strip.secondary {
            bottom: 220px; /* Elevated for visibility within Hero */
            background: #ffffff; /* Stark White */
            z-index: 15;
            transform: rotate(3deg);
            box-shadow: 0 5px 20px rgba(0,0,0,0.2);
        }

        .strip-content {
            display: flex;
            white-space: nowrap;
            animation: strip-scroll 15s linear infinite; /* Faster for more energy */
        }

        .strip-content.reverse {
            animation: strip-scroll 20s linear infinite reverse;
        }

        .strip-content span {
            font-family: var(--sans);
            font-weight: 900;
            text-transform: uppercase;
            font-size: 1.1rem; /* Slightly larger */
            color: #ffffff;
            padding: 0 25px;
            letter-spacing: 2px;
            display: flex;
            align-items: center;
        }

        .transition-strip.secondary .strip-content span {
            color: #ff0000; /* Red text on white strip */
        }

        .strip-content span::after {
            content: '●';
            margin-left: 25px;
            color: rgba(0,0,0,0.2);
        }
        
        .transition-strip.secondary .strip-content span::after {
            color: rgba(255,0,0,0.2);
        }

        @keyframes strip-scroll {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }

        /* Swag Cat Character - Larger Focal Point */
        .hero-character {
            position: absolute;
            right: 10%;
            bottom: 250px;
            width: 40vw;
            max-width: 500px;
            z-index: 20;
            pointer-events: none;
            opacity: 0;
            transform: translateX(50px);
        }

        .hero-character svg {
            width: 100%;
            height: auto;
            filter: drop-shadow(0 20px 40px rgba(0,0,0,0.5));
        }

        /* Background Quote */
        .hero-quote {
            position: absolute;
            top: 40%;
            left: 50%;
            transform: translate(-50%, -50%);
            width: 100%;
            text-align: center;
            font-family: var(--sans);
            font-size: clamp(4rem, 15vw, 12rem);
            font-weight: 900;
            color: rgba(255, 255, 255, 0.03);
            text-transform: uppercase;
            line-height: 0.8;
            pointer-events: none;
            z-index: 0;
            white-space: nowrap;
        }

        /* Vertical Navigation Rail */
        .nav-rail {
            position: fixed;
            left: 30px;
            top: 50%;
            transform: translateY(-50%);
            display: flex;
            flex-direction: column;
            gap: 45px;
            z-index: 1000; /* Higher priority */
            mix-blend-mode: difference;
        }
 
        .nav-item {
            font-family: var(--sans);
            font-size: 0.7rem; 
            font-weight: 800; 
            text-transform: uppercase;
            letter-spacing: 2px; 
            color: #fff; 
            writing-mode: vertical-lr;
            transform: rotate(180deg);
            transition: transform 0.3s ease, opacity 0.3s ease;
        }
 
        .nav-item:hover {
            transform: rotate(180deg) scale(1.1);
            opacity: 0.8;
        }
 
        .nav-item.active {
            opacity: 1;
        }

        /* Grid Background */
        #hero-canvas {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            z-index: -1;
            pointer-events: none;
        }

        /* About Section - Transparent to show white body background */
        #about {
            color: #0d0d0d;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 80px;
            align-items: center;
            position: relative;
            z-index: 5;
            padding: 150px 10% 150px 10%; /* Adjusted for new hero margin */
        }

        .stats-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 20px;
        }

        .stat-block {
            padding: 30px;
            background: rgba(0, 0, 0, 0.05); /* Stronger background */
            border: 1px solid rgba(0, 0, 0, 0.1); /* Visible border */
            box-shadow: 6px 6px 0 rgba(0,0,0,0.08); /* Brutalist punch */
            transition: transform 0.3s ease;
        }
 
        .stat-block:hover {
            transform: translate(-4px, -4px);
            box-shadow: 10px 10px 0 rgba(0,0,0,0.12);
        }

        .stat-number {
            display: block;
            font-size: 2.5rem;
            font-family: var(--sans);
            color: var(--accent);
            margin-bottom: 5px;
        }

        .stat-label {
            font-size: 0.9rem;
            color: #666;
        }

        .about-text p {
            font-size: 1.25rem;
            margin-bottom: 30px;
            color: #1a1a1a;
            font-weight: 500;
        }

        .skills-container {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
        }

        .skill-chip {
            padding: 8px 16px;
            background: rgba(108, 99, 255, 0.08);
            border: 1px solid rgba(108, 99, 255, 0.2);
            border-radius: 50px;
            font-size: 0.85rem;
            color: var(--accent);
            transition: 0.3s;
        }

        .skill-chip:hover {
            background: var(--accent);
            color: #fff;
        }

        /* Projects Section - Explicit Dark */
        #projects {
            background-color: var(--bg);
            position: relative;
            z-index: 10;
            padding-top: 100px;
        }

        #projects h2 {
            font-size: 3rem;
            margin-bottom: 60px;
        }

        .project-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 40px;
        }

        .project-card {
            background: rgba(255, 255, 255, 0.02);
            padding: 40px;
            border: 1px solid rgba(255, 255, 255, 0.05);
            position: relative;
            transition: transform 0.4s cubic-bezier(0.23, 1, 0.32, 1);
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }

        .project-card::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0; bottom: 0;
            border: 1px solid var(--accent);
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s;
        }

        .project-card:hover {
            transform: translateY(-8px);
        }

        .project-card:hover::before {
            opacity: 1;
        }

        .project-card:hover .project-tags span {
            text-shadow: 0 0 10px var(--accent-glow);
        }

        .project-tags {
            font-size: 0.8rem;
            color: var(--accent);
            margin-bottom: 15px;
            display: block;
        }

        .project-title {
            font-size: 1.8rem;
            margin-bottom: 15px;
        }

        .project-desc {
            color: var(--text-dim);
            font-size: 1rem;
            margin-bottom: 30px;
        }

        .project-link {
            font-family: var(--sans);
            font-size: 0.9rem;
            text-decoration: underline;
            text-underline-offset: 4px;
        }

        /* DSA Strip */
        .marquee-container {
            width: 100vw;
            margin-left: -10%;
            overflow: hidden;
            background: var(--bg); /* Explicit dark */
            padding: 20px 0;
            border-top: 1px solid rgba(255, 255, 255, 0.03);
            border-bottom: 1px solid rgba(255, 255, 255, 0.03);
        }

        .marquee {
            display: flex;
            white-space: nowrap;
            animation: scroll 40s linear infinite;
        }

        .marquee span {
            font-size: 1.2rem;
            font-family: var(--sans);
            color: var(--accent);
            opacity: 0.2;
            padding: 0 40px;
            text-transform: lowercase;
        }

        @keyframes scroll {
            0% { transform: translateX(0); }
            100% { transform: translateX(-50%); }
        }

        /* Code Catalysts Section */
        #community {
            position: relative;
            background-color: var(--bg); /* Explicit dark */
            background-image: radial-gradient(circle at 50% 50%, rgba(108, 99, 255, 0.03) 0%, transparent 80%);
        }

        .community-content {
            max-width: 800px;
            margin-bottom: 60px;
        }

        .community-grid {
            display: flex;
            flex-wrap: wrap;
            gap: 15px;
        }

        .member-chip {
            padding: 10px 20px;
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.05);
            font-family: var(--sans);
            font-size: 0.9rem;
            opacity: 0;
        }

        /* Footer / Contact */
        #contact {
            text-align: center;
            overflow: hidden;
            position: relative;
            background-color: var(--bg);
        }

        #contact h2 {
            font-size: 4rem;
            margin-bottom: 60px;
        }

        .contact-links {
            display: flex;
            justify-content: center;
            gap: 60px;
            margin-bottom: 80px;
            position: relative;
            z-index: 2;
        }

        .contact-item {
            font-size: 2.5rem;
            transition: 0.3s;
        }

        .contact-item i {
            display: inline-block;
        }

        .footer-line {
            color: var(--text-dim);
            font-size: 1rem;
            position: relative;
            z-index: 2;
        }

        /* Lava Lamp Background - Fixed for better blending */
        .lava-container {
            position: absolute;
            top: 0; left: 0; width: 100%; height: 100%;
            z-index: 0;
            overflow: hidden;
            filter: blur(120px);
            opacity: 0.3;
            pointer-events: none;
        }

        .blob {
            position: absolute;
            border-radius: 50%;
            will-change: transform;
        }

        .blob-1 {
            width: 40vw;
            height: 40vw;
            background: var(--accent);
            top: 10%;
            left: 20%;
        }

        .blob-2 {
            width: 50vw;
            height: 50vw;
            background: #1a1a1a;
            bottom: 10%;
            right: 15%;
        }

        /* Noise Texture to prevent banding */
        body::before {
            content: "";
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: url("https://grainy-gradients.vercel.app/noise.svg");
            opacity: 0.04;
            pointer-events: none;
            z-index: 9999;
        }

        /* Mobile Adjustments */
        @media (max-width: 768px) {
            * { cursor: auto !important; }
            #cursor-dot, #cursor-ring, #scroll-progress { display: none; }
            section { padding: 80px 5%; }
            #about { grid-template-columns: 1fr; gap: 40px; }
            .contact-links { gap: 30px; }
            #contact h2 { font-size: 3rem; }
        }
    </style>
</head>
<body>

    <div id="cursor-dot"></div>
    <div id="cursor-ring"></div>

    <div id="scroll-progress">
        <div id="scroll-bar"></div>
    </div>

    <!-- Vertical Navigation Rail -->
    <div class="nav-rail">
        <a href="#hero" class="nav-item active">Home</a>
        <a href="#about" class="nav-item">About</a>
        <a href="#projects" class="nav-item">Work</a>
        <a href="#contact" class="nav-item">Contact</a>
    </div>

    <main>
        <!-- Section 1: Hero -->
        <section id="hero">
            <div class="hero-quote">BREAK THINGS · BUILD STUFF</div>
            <canvas id="hero-canvas"></canvas>
            <div class="hero-sub">CSE @ GLA University · Mathura</div>
            <h1 id="hero-title">sarthak saini</h1>
            <div class="hero-bio">
                I build ML pipelines, break things in Java, and <br>
                somehow ended up leading a student dev team.
            </div>
            
            <!-- Secondary Strip (Bottom Layer) -->
            <div class="transition-strip secondary">
                <div class="strip-content reverse">
                    <span>Code Catalysts</span><span>Open Source</span><span>GLA University</span><span>System Design</span><span>Code Catalysts</span><span>Open Source</span><span>GLA University</span><span>System Design</span><span>Code Catalysts</span><span>Open Source</span><span>GLA University</span><span>System Design</span><span>Code Catalysts</span><span>Open Source</span><span>GLA University</span><span>System Design</span><span>Code Catalysts</span><span>Open Source</span><span>GLA University</span><span>System Design</span><span>Code Catalysts</span><span>Open Source</span><span>GLA University</span><span>System Design</span>
                </div>
            </div>

            <!-- Primary Strip (Top Layer) -->
            <!-- Primary Strip (Top Layer) -->
            <div class="transition-strip">
                <div class="strip-content">
                    <span>Machine Learning</span><span>Web Development</span><span>Data Structures</span><span>UI/UX</span><span>Java</span><span>Python</span><span>Machine Learning</span><span>Web Development</span><span>Data Structures</span><span>UI/UX</span><span>Java</span><span>Python</span><span>Machine Learning</span><span>Web Development</span><span>Data Structures</span><span>UI/UX</span><span>Java</span><span>Python</span><span>Machine Learning</span><span>Web Development</span><span>Data Structures</span><span>UI/UX</span><span>Java</span><span>Python</span>
                </div>
            </div>

            <!-- Interactive SVG Swag Cat -->
            <div class="hero-character" id="swag-cat">
                <svg viewBox="0 0 200 200" width="200" height="200">
                    <!-- Body/Chest -->
                    <path d="M40,190 Q100,140 160,190" stroke="white" stroke-width="4" fill="none" opacity="0.3"/>
                    <!-- Head -->
                    <rect x="50" y="60" width="100" height="80" rx="20" fill="#1a1a1a" stroke="white" stroke-width="2"/>
                    <!-- Ears -->
                    <path d="M60,65 L40,30 L80,60 Z" fill="#1a1a1a" stroke="white" stroke-width="2"/>
                    <path d="M140,65 L160,30 L120,60 Z" fill="#1a1a1a" stroke="white" stroke-width="2"/>
                    <!-- Sunglasses -->
                    <rect x="60" y="85" width="80" height="30" rx="5" fill="#000" stroke="#ff0000" stroke-width="2"/>
                    <!-- Interactive Eyes (inside sunglasses) -->
                    <g id="cat-eyes">
                        <circle cx="80" cy="100" r="3" fill="#ff0000" class="eye-pupil"/>
                        <circle cx="120" cy="100" r="3" fill="#ff0000" class="eye-pupil"/>
                    </g>
                    <!-- Mouth/Cool Expression -->
                    <path d="M90,125 Q100,130 110,125" stroke="white" stroke-width="2" fill="none"/>
                </svg>
            </div>
        </section>

        <!-- Section 2: About -->
        <section id="about">
            <div class="stats-grid">
                <div class="stat-block">
                    <span class="stat-number" data-count="10">0</span>
                    <span class="stat-label">repos</span>
                </div>
                <div class="stat-block">
                    <span class="stat-number" data-count="3">0</span>
                    <span class="stat-label">real projects</span>
                </div>
                <div class="stat-block">
                    <span class="stat-number" data-count="1">0</span>
                    <span class="stat-label">community (Code Catalysts)</span>
                </div>
                <div class="stat-block">
                    <span class="stat-number" data-count="50">0</span>
                    <span class="stat-label">way too many LeetCode tabs open</span>
                </div>
            </div>
            <div class="about-text">
                <p>
                    I'm a second-year CSE student who got tired of just studying algorithms and decided to actually build things. I got into ML not because it was trendy but because I wanted to see if a model could actually predict something useful — turns out, it can predict heart disease with ~80% accuracy, which is both cool and slightly terrifying.
                </p>
                <p>
                    I also help run Code Catalysts, which is basically a group of students who build instead of just attending lectures.
                </p>
                <div class="skills-container">
                    <span class="skill-chip">Python</span>
                    <span class="skill-chip">scikit-learn</span>
                    <span class="skill-chip">MLflow</span>
                    <span class="skill-chip">DVC</span>
                    <span class="skill-chip">Random Forest</span>
                    <span class="skill-chip">Java</span>
                    <span class="skill-chip">JavaScript</span>
                    <span class="skill-chip">Supabase</span>
                    <span class="skill-chip">Vite</span>
                    <span class="skill-chip">Git</span>
                    <span class="skill-chip">Streamlit</span>
                    <span class="skill-chip">SQL</span>
                </div>
            </div>
        </section>

        <!-- Section 3: Projects -->
        <section id="projects">
            <h2>stuff i've built</h2>
            <div class="project-grid">
                <!-- Card 1 -->
                <div class="project-card">
                    <div>
                        <span class="project-tags">Python · ML Pipeline · DVC · MLflow</span>
                        <h3 class="project-title">Heart Disease Prediction Pipeline</h3>
                        <p class="project-desc">A production-style ML pipeline that actually follows proper software practices — DVC for reproducibility, MLflow for experiment tracking, feature engineering with derived indicators like cholesterol-age ratio. Hit 79.6% accuracy and 87.6% ROC AUC on the first proper run.</p>
                    </div>
                    <a href="https://github.com/sarthaksaini041/HealthcareAnalysis" target="_blank" class="project-link">github.com/sarthaksaini041/HealthcareAnalysis</a>
                </div>
                <!-- Card 2 -->
                <div class="project-card">
                    <div>
                        <span class="project-tags">Python · Random Forest · Streamlit</span>
                        <h3 class="project-title">Retail Demand Forecasting</h3>
                        <p class="project-desc">Predicts how many units of a product a store will sell given its category, region, price, discounts, and whether it's a holiday. Compared Linear Regression, Decision Trees, and Random Forest — RF won on MAE/RMSE. Has a Streamlit UI so non-technical people can actually use it.</p>
                    </div>
                    <a href="https://github.com/sarthaksaini041/Product-Predict" target="_blank" class="project-link">github.com/sarthaksaini041/Product-Predict</a>
                </div>
                <!-- Card 3 -->
                <div class="project-card">
                    <div>
                        <span class="project-tags">JavaScript · Vite · Supabase · Vercel</span>
                        <h3 class="project-title">Code Catalysts — Student Builder Community</h3>
                        <p class="project-desc">Built the entire website for our college tech community from scratch. Full application pipeline, admin portal, Supabase backend, deployed on Vercel. It started as 'let's just make a landing page' and ended up being a real web app with migrations and everything.</p>
                    </div>
                    <a href="https://github.com/sarthaksaini041/CodeCatalysts" target="_blank" class="project-link">github.com/sarthaksaini041/CodeCatalysts</a>
                </div>
            </div>
        </section>

        <!-- Section 4: DSA Marquee -->
        <div class="marquee-container">
            <div class="marquee">
                <span>Java · Arrays · Strings · Binary Search · Two Pointers · Recursion · HashMaps · Trees · Java · Arrays · Strings · Binary Search · Two Pointers · Recursion · HashMaps · Trees · Java · Arrays · Strings · Binary Search · Two Pointers · Recursion · HashMaps · Trees</span>
                <span>Java · Arrays · Strings · Binary Search · Two Pointers · Recursion · HashMaps · Trees · Java · Arrays · Strings · Binary Search · Two Pointers · Recursion · HashMaps · Trees · Java · Arrays · Strings · Binary Search · Two Pointers · Recursion · HashMaps · Trees</span>
            </div>
        </div>

        <!-- Section 5: Code Catalysts Spotlight -->
        <section id="community">
            <div class="community-content">
                <p>Code Catalysts is a student community I'm part of at GLA University. We build actual projects — web, app, AI, design — instead of just sitting through lectures. 11 people, one GitHub org, zero budget, a lot of Vercel deployments.</p>
            </div>
            <div class="community-grid" id="member-grid">
                <!-- Chips added via JS -->
            </div>
        </section>

        <!-- Section 6: Contact -->
        <section id="contact">
            <div class="lava-container">
                <div class="blob blob-1"></div>
                <div class="blob blob-2"></div>
            </div>
            <h2>let's talk</h2>
            <div class="contact-links">
                <a href="https://github.com/sarthaksaini041" target="_blank" class="contact-item" id="link-github">
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.042-1.416-4.042-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
                </a>
                <a href="https://linkedin.com/in/sarthakksaini" target="_blank" class="contact-item" id="link-linkedin">
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="currentColor"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
                </a>
                <a href="https://leetcode.com/u/6Jf9Gaf4vp/" target="_blank" class="contact-item" id="link-leetcode">
                    <svg width="40" height="40" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M13.483 0a1.374 1.374 0 0 0-.961.438L7.116 6.226l-3.854 4.126a5.266 5.266 0 0 0-1.209 2.104 5.35 5.35 0 0 0-.125.513 5.527 5.527 0 0 0 .062 2.362 5.83 5.83 0 0 0 .349 1.017 5.938 5.938 0 0 0 1.271 1.818l4.277 4.193.039.038c2.248 2.165 5.852 2.133 8.063-.074l2.396-2.392c.54-.54.54-1.414.074-1.954l-5.698-5.719c-.54-.54-1.415-.54-1.955 0-.54.54-.54 1.415 0 1.955l4.278 4.278c.27.27.638.405 1.006.405.367 0 .736-.135 1.005-.405l2.396-2.396c.27-.27.405-.638.405-1.006s-.135-.736-.405-1.005l-4.278-4.278c-.27-.27-.638-.405-1.006-.405-.367 0-.736.135-1.005.405l-2.613 2.613c-.27.27-.638.405-1.006.405-.367 0-.736-.135-1.005-.405-.54-.54-.54-1.415 0-1.955l2.613-2.613c.54-.54 1.415-.54 1.955 0l2.396 2.396c.27.27.638.405 1.006.405.367 0 .736-.135 1.005-.405l2.396-2.396c.27-.27.405-.638.405-1.006s-.135-.736-.405-1.005L14.444.438A1.374 1.374 0 0 0 13.483 0z"/>
                    </svg>
                </a>
            </div>
            <p class="footer-line">GLA University, Mathura · open to internships and collabs</p>
        </section>
    </main>

    <!-- Scripts -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>

    <script>
        // --- INITIALIZATION ---
        gsap.registerPlugin(ScrollTrigger);
        const isMobile = window.innerWidth <= 768;

        const memberNames = [
            "Rudraksh Pandey", "Sarthak Saini", "Tanishka Agarwal", 
            "Ansh Aditya", "Radhika Maheshwari", "Ananya Khatri", 
            "Prakhar Saxena", "Sparsh Raj", "Somya Purohit", 
            "Shatakshi Bajpai", "Shambhavi"
        ];

        const memberGrid = document.getElementById('member-grid');
        memberNames.forEach(name => {
            const chip = document.createElement('div');
            chip.className = 'member-chip';
            chip.innerText = name;
            memberGrid.appendChild(chip);
        });

        // Split text for hero animation
        const heroName = document.getElementById('hero-title');
        const chars = heroName.innerText.split('');
        heroName.innerHTML = chars.map(c => `<span class="char">${c === ' ' ? '&nbsp;' : c}</span>`).join('');

        // --- PAGE LOAD ---
        window.addEventListener('load', () => {
            gsap.to('body', { opacity: 1, duration: 0.4, delay: 0.3 });

            // Hero Animation
            const tl = gsap.timeline();
            tl.to('.char', {
                y: 0,
                stagger: 0.05,
                duration: 1.2,
                ease: "elastic.out(1, 0.3)",
                delay: 0.5
            })
            .to('.hero-sub', { opacity: 1, y: 0, duration: 0.5 }, "-=0.8")
            .to('.hero-bio', { opacity: 1, y: 0, duration: 0.5 }, "-=0.3")
            .to('.hero-character', { opacity: 1, x: 0, duration: 1, ease: "power2.out" }, "-=0.5");

            // Floating Cat Animation
            gsap.to('#swag-cat svg', {
                y: -10,
                duration: 3,
                repeat: -1,
                yoyo: true,
                ease: "sine.inOut"
            });
        });

        // Cat Eye Tracking
        const pupils = document.querySelectorAll('.eye-pupil');
        window.addEventListener('mousemove', (e) => {
            const mouseX = e.clientX;
            const mouseY = e.clientY;

            pupils.forEach(pupil => {
                const rect = pupil.getBoundingClientRect();
                const pupilX = rect.left + rect.width / 2;
                const pupilY = rect.top + rect.height / 2;

                const angle = Math.atan2(mouseY - pupilY, mouseX - pupilX);
                const distance = Math.min(4, Math.hypot(mouseX - pupilX, mouseY - pupilY) / 50);

                const moveX = Math.cos(angle) * distance;
                const moveY = Math.sin(angle) * distance;

                gsap.to(pupil, { x: moveX, y: moveY, duration: 0.1 });
            });
        });

        // --- CURSOR ---
        const dot = document.getElementById('cursor-dot');
        const ring = document.getElementById('cursor-ring');
        let mouseX = 0, mouseY = 0;
        let ringX = 0, ringY = 0;

        // Cursor scaling and color inversion
        const aboutSection = document.getElementById('about');
        
        if (!isMobile) {
            window.addEventListener('mousemove', (e) => {
                mouseX = e.clientX;
                mouseY = e.clientY;
                
                gsap.to(dot, { x: mouseX, y: mouseY, duration: 0 });
            });

            // Smooth lagging ring
            function animateCursor() {
                ringX += (mouseX - ringX) * 0.15;
                ringY += (mouseY - ringY) * 0.15;
                ring.style.left = ringX + 'px';
                ring.style.top = ringY + 'px';

                // Check if over white section
        // Dynamic Nav Color and Active State on Scroll
        // Dynamic Nav Active State on Scroll
        window.addEventListener('scroll', () => {
            const aboutRect = aboutSection.getBoundingClientRect();
            const navItems = document.querySelectorAll('.nav-item');
            
            // Cursor Inversion (Keep for ring/dot)
            if (aboutRect.top <= 100 && aboutRect.bottom >= 100) {
                ring.style.borderColor = '#000';
                dot.style.background = '#000';
            } else {
                ring.style.borderColor = 'var(--accent)';
                dot.style.background = 'var(--accent)';
            }

            // Active State (ScrollSpy)
            const sections = ['hero', 'about', 'projects', 'community', 'contact'];
            let current = 'hero';
            
            sections.forEach(id => {
                const section = document.getElementById(id);
                if (section) {
                    const rect = section.getBoundingClientRect();
                    if (rect.top <= 200) current = id;
                }
            });

            navItems.forEach(item => {
                item.classList.remove('active');
                if (item.getAttribute('href') === `#${current}`) {
                    item.classList.add('active');
                }
            });
        });

                requestAnimationFrame(animateCursor);
            }
            animateCursor();

            document.querySelectorAll('a, .skill-chip, .project-card, .stat-block, .contact-item').forEach(el => {
                el.addEventListener('mouseenter', () => {
                    gsap.to(ring, { width: 20, height: 20, duration: 0.3 });
                });
                el.addEventListener('mouseleave', () => {
                    gsap.to(ring, { width: 40, height: 40, duration: 0.3 });
                });
            });
        }

        // --- SCROLL PROGRESS ---
        gsap.to('#scroll-bar', {
            height: '100%',
            ease: 'none',
            scrollTrigger: {
                trigger: 'body',
                start: 'top top',
                end: 'bottom bottom',
                scrub: true
            }
        });

        // --- PARTICLE GRID ---
        const canvas = document.getElementById('hero-canvas');
        if (!isMobile && canvas) {
            const ctx = canvas.getContext('2d');
            let width, height;
            const spacing = 40;
            const dots = [];

            function resize() {
                width = canvas.width = window.innerWidth;
                height = canvas.height = window.innerHeight;
                dots.length = 0;
                for (let x = spacing / 2; x < width; x += spacing) {
                    for (let y = spacing / 2; y < height; y += spacing) {
                        dots.push({ x, y, baseX: x, baseY: y });
                    }
                }
            }

            window.addEventListener('resize', resize);
            resize();

            function drawGrid() {
                ctx.clearRect(0, 0, width, height);
                ctx.beginPath();
                ctx.strokeStyle = 'rgba(255, 255, 255, 0.04)';
                ctx.lineWidth = 0.5;

                dots.forEach(dot => {
                    const dx = mouseX - dot.x;
                    const dy = mouseY - dot.y;
                    const dist = Math.sqrt(dx * dx + dy * dy);
                    const maxDist = 200;
                    
                    if (dist < maxDist) {
                        const force = (maxDist - dist) / maxDist;
                        dot.x = dot.baseX - dx * force * 0.3;
                        dot.y = dot.baseY - dy * force * 0.3;
                    } else {
                        dot.x += (dot.baseX - dot.x) * 0.1;
                        dot.y += (dot.baseY - dot.y) * 0.1;
                    }

                    ctx.fillStyle = 'rgba(255, 0, 0, 0.3)'; // Red dots
                    ctx.fillRect(dot.x - 1, dot.y - 1, 2, 2);
                });

                // Grid lines
                for (let x = spacing / 2; x < width; x += spacing) {
                    ctx.moveTo(x, 0); ctx.lineTo(x, height);
                }
                for (let y = spacing / 2; y < height; y += spacing) {
                    ctx.moveTo(0, y); ctx.lineTo(width, y);
                }
                ctx.stroke();

                requestAnimationFrame(drawGrid);
            }
            drawGrid();
        }

        // --- SECTION ANIMATIONS ---
        
        // Stats count-up
        document.querySelectorAll('.stat-number').forEach(stat => {
            const target = parseInt(stat.getAttribute('data-count'));
            ScrollTrigger.create({
                trigger: stat,
                start: "top 90%",
                onEnter: () => {
                    let count = { val: 0 };
                    gsap.to(count, {
                        val: target,
                        duration: 2,
                        onUpdate: () => stat.innerText = Math.floor(count.val),
                        ease: "power2.out"
                    });
                }
            });
        });

        // Generic Fade-in Stagger
        const fadeTriggers = [
            { el: '.stat-block', trigger: '.stats-grid' },
            { el: '.skill-chip', trigger: '.skills-container' },
            { el: '.project-card', trigger: '.project-grid' },
            { el: '.member-chip', trigger: '.community-grid' }
        ];

        fadeTriggers.forEach(config => {
            gsap.from(config.el, {
                y: 40,
                opacity: 0,
                duration: 0.7,
                stagger: 0.12,
                ease: "power2.out",
                scrollTrigger: {
                    trigger: config.trigger,
                    start: "top 85%"
                }
            });
        });

        // Floating loop for projects (Desktop Only)
        if (!isMobile) {
            gsap.to('.project-card', {
                y: "-=10",
                duration: 3,
                repeat: -1,
                yoyo: true,
                ease: "sine.inOut",
                stagger: 0.5
            });
        }


        // --- STRIP INTERACTION ---
        gsap.to('.transition-strip', {
            x: -100,
            scrollTrigger: {
                trigger: '#hero',
                start: 'bottom bottom',
                end: 'bottom top',
                scrub: true
            }
        });

        gsap.to('.transition-strip.secondary', {
            x: 100,
            scrollTrigger: {
                trigger: '#hero',
                start: 'bottom bottom',
                end: 'bottom top',
                scrub: true
            }
        });

        // Dynamic Hero Corner Rounding
        gsap.to('#hero', {
            borderRadius: "0 0 150px 150px",
            scrollTrigger: {
                trigger: '#hero',
                start: 'top top',
                end: '20% top',
                scrub: true
            }
        });


        // Community members mesh gradient blobs movement
        gsap.to('.blob-1', {
            x: "20%", y: "10%", duration: 10, repeat: -1, yoyo: true, ease: "sine.inOut"
        });
        gsap.to('.blob-2', {
            x: "-10%", y: "-15%", duration: 12, repeat: -1, yoyo: true, ease: "sine.inOut"
        });

        // Contact animations
        document.getElementById('link-github').addEventListener('mouseenter', () => {
            gsap.to('#link-github svg', { rotation: 360, duration: 0.6 });
        });
        document.getElementById('link-linkedin').addEventListener('mouseenter', () => {
            gsap.to('#link-linkedin svg', { y: -10, yoyo: true, repeat: 1, duration: 0.3 });
        });
        document.getElementById('link-leetcode').addEventListener('mouseenter', () => {
            gsap.to('#link-leetcode svg', { color: 'var(--accent)', duration: 0.2, repeat: 3, yoyo: true });
        });
        document.getElementById('link-leetcode').addEventListener('mouseleave', () => {
            gsap.to('#link-leetcode svg', { color: 'inherit', duration: 0.2 });
        });

    </script>
</body>
</html>
